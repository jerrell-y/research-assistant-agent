# Anthropic (LLM)
ANTHROPIC_API_KEY=INSERT_KEY_HERE

# Tavily (web search — app.tavily.com)
TAVILY_API_KEY=INSERT_KEY_HERE

# Cohere (reranking — dashboard.cohere.com)
COHERE_API_KEY=INSERT_KEY_HERE

# Qdrant (vector DB — run locally with Docker)
# docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=research_agent

# Agent settings
MAX_SEARCH_RESULTS=5          # Tavily results per sub-question
CHUNK_SIZE=500                 # Tokens per chunk
CHUNK_OVERLAP=50               # Overlap between chunks
TOP_K_RETRIEVE=20              # Candidates before reranking
TOP_K_RERANK=5                 # Final chunks passed to LLM
MAX_SUB_QUESTIONS=4            # Max decomposed sub-questions
